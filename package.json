{
  "name": "yatra-playwright-framework",
  "version": "1.0.0",
  "description": "Production-grade Playwright + TypeScript framework for Yatra.com",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:api": "npx playwright test tests/api/",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:parallel": "npx playwright test --workers=4",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "faker": "^6.6.6",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "allure-playwright": "^3.0.0-beta.5",
    "allure-commandline": "^2.29.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0"
  }
}
